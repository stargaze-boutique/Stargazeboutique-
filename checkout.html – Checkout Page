<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stargaze Boutique - Checkout</title>
<style>
body{font-family:Arial;margin:20px;background:#f5f5f5;}
.header{display:flex;justify-content:space-between;align-items:center;padding:12px;background:#111;color:white;margin-bottom:20px;}
.header a{color:white;text-decoration:none;margin-left:10px;}
input, textarea{padding:8px;margin:5px 0;width:100%;max-width:350px;border-radius:4px;border:1px solid #ccc;}
button{background:#ff4081;color:white;border:none;padding:10px 16px;cursor:pointer;border-radius:4px;margin-top:10px;}
</style>
</head>
<body>

<div class="header">
<h2>Stargaze Boutique</h2>
<div>
<a href="index.html">🏠 Home</a>
<a href="shop.html">Shop</a>
<a href="cart.html">🛒 Cart</a>
<a href="admin.html">Admin</a>
</div>
</div>

<h2>Checkout</h2>

<input id="name" placeholder="Your Name"><br>
<input id="phone" placeholder="Phone Number"><br>
<textarea id="address" placeholder="Delivery Address"></textarea><br>
<button onclick="checkout()">Place Order via WhatsApp</button>

<script>
// Ready-to-use products
let products = [
  {name:"Premium Red Lehenga", price:149, image:"images/lehenga1.jpg", category:"Lehenga"},
  {name:"Elegant Bridal Lehenga", price:199, image:"images/lehenga2.jpg", category:"Lehenga"},
  {name:"Stylish Saree", price:79, image:"images/saree1.jpg", category:"Saree"},
  {name:"Designer Kurti", price:49, image:"images/kurti1.jpg", category:"Kurti"},
  {name:"Party Gown", price:119, image:"images/gown1.jpg", category:"Gown"},
  {name:"Pakistan Suit Set", price:129, image:"images/pakistan_suit1.jpg", category:"Pakistan Suit"},
  {name:"India Suit Set", price:139, image:"images/india_suit1.jpg", category:"India Suit"},
  {name:"Ladies Innerwear Set", price:39, image:"images/innerwear1.jpg", category:"Ladies Innerwear"}
];
localStorage.setItem("products", JSON.stringify(products));

function checkout(){
    let name = document.getElementById("name").value.trim();
    let phoneNo = document.getElementById("phone").value.trim();
    let address = document.getElementById("address").value.trim();

    if(!name || !phoneNo || !address){
        alert("Please fill all fields");
        return;
    }

    let cart = JSON.parse(localStorage.getItem("cart")) || [];
    if(cart.length===0){
        alert("Your cart is empty");
        return;
    }

    let phone="971XXXXXXXXX"; // Replace with your WhatsApp number
    let message = `Order from ${name}\nPhone: ${phoneNo}\nAddress: ${address}\n\nItems:\n`;
    message += cart.map(i=>i.name+" - $"+i.price).join("\n");

    window.open("https://wa.me/"+phone+"?text="+encodeURIComponent(message));
}
</script>

</body>
</html>
