<!DOCTYPE html>
<html>
<head>
<title>Admin Panel</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<style>

body{
font-family:Arial;
padding:20px;
}

input{
display:block;
margin:10px 0;
padding:10px;
width:250px;
}

button{
padding:10px 15px;
cursor:pointer;
}

img{
margin-top:10px;
}

</style>
</head>

<body>

<h1>Admin Panel</h1>

<h3>Add Product</h3>

<input id="name" placeholder="Product Name">

<input id="price" placeholder="Price">

<input id="category" placeholder="Category">

<input id="badge" placeholder="Badge (New / Sale)">

<input id="stock" placeholder="Stock">

<!-- Manual Image URL -->
<input id="imageUrl" placeholder="Image URL (Optional)">

<!-- Automatic Image Upload -->
<input type="file" id="imageUpload">

<img id="preview" width="120">

<button onclick="addProduct()">Add Product</button>

<hr>

<h2>All Products</h2>

<div id="productList"></div>

<script>

let products = JSON.parse(localStorage.getItem("products")) || [];

let uploadedImage="";

// preview uploaded image
document.getElementById("imageUpload").addEventListener("change",function(e){

const file=e.target.files[0];

if(!file) return;

const reader=new FileReader();

reader.onload=function(event){

uploadedImage=event.target.result;

document.getElementById("preview").src=uploadedImage;

}

reader.readAsDataURL(file);

});

// add product
function addProduct(){

const name=document.getElementById("name").value;
const price=document.getElementById("price").value;
const category=document.getElementById("category").value;
const badge=document.getElementById("badge").value;
const stock=document.getElementById("stock").value;

let image=document.getElementById("imageUrl").value;

if(uploadedImage){
image=uploadedImage;
}

const product={
id:Date.now(),
name,
price,
image,
category,
badge,
stock,
sizes:["S","M","L","XL","XXL"]
};

products.push(product);

localStorage.setItem("products",JSON.stringify(products));

renderProducts();

clearForm();

}

// render products
function renderProducts(){

const container=document.getElementById("productList");

container.innerHTML="";

products.forEach((p,i)=>{

container.innerHTML+=`

<div style="border-bottom:1px solid #ccc;padding:10px">

<img src="${p.image}" width="60">

<b>${p.name}</b> - ₹${p.price}

<button onclick="deleteProduct(${i})">
Delete
</button>

</div>

`;

});

}

// delete product
function deleteProduct(i){

products.splice(i,1);

localStorage.setItem("products",JSON.stringify(products));

renderProducts();

}

// clear form
function clearForm(){

document.getElementById("name").value="";
document.getElementById("price").value="";
document.getElementById("category").value="";
document.getElementById("badge").value="";
document.getElementById("stock").value="";
document.getElementById("imageUrl").value="";
document.getElementById("preview").src="";
uploadedImage="";

}

renderProducts();

</script>

</body>
</html>
