<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stargazeboutique - Mockup</title>
<link rel="stylesheet" href="css/style.css">
</head>
<body>

<header>
  <img src="images/logo.png" alt="Stargazeboutique Logo" style="height:60px;">
  <nav>
    <a href="index.html">Home</a>
    <a href="shop.html">Shop</a>
    <a href="cart.html">Cart</a>
    <a href="wishlist.html">Wishlist</a>
    <a href="contact.html">Contact</a>
    <a href="admin.html">Admin</a>
  </nav>
</header>

<main>

  <!-- Banner -->
  <div class="banner">
    <img src="images/banner-free-shipping.png" alt="Free Shipping ₹5000+">
  </div>

  <!-- Featured Products / Shop Mockup -->
  <section class="category-section">
    <h2>Featured Products</h2>
    <div class="product-grid">

      <div class="product-card">
        <img src="images/product-images/kurti1.jpg" alt="Designer Kurti Set">
        <h3>Designer Kurti Set</h3>
        <p>Price: 149 AED</p>
        <p>Material: Cotton</p>
        <button>Edit</button>
        <button>Delete</button>
      </div>

      <div class="product-card">
        <img src="images/product-images/lehenga1.jpg" alt="Wedding Lehenga">
        <h3>Wedding Lehenga</h3>
        <p>Price: 399 AED</p>
        <p>Material: Silk</p>
        <button>Edit</button>
        <button>Delete</button>
      </div>

      <div class="product-card">
        <img src="images/product-images/saree1.jpg" alt="Party Wear Saree">
        <h3>Party Wear Saree</h3>
        <p>Price: 199 AED</p>
        <p>Material: Georgette</p>
        <button>Edit</button>
        <button>Delete</button>
      </div>

      <div class="product-card">
        <img src="images/product-images/gown1.jpg" alt="Luxury Gown">
        <h3>Luxury Gown</h3>
        <p>Price: 299 AED</p>
        <p>Material: Net</p>
        <button>Edit</button>
        <button>Delete</button>
      </div>

    </div>
  </section>

</main>

<footer>
  Stargazeboutique © 2026 | <a href="privacy.html">Privacy</a> | <a href="disclaimer.html">Disclaimer</a>
</footer>

</body>
</html>
