<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stargazeboutique - Full Store Mockup</title>
<style>
  body { font-family: Arial, sans-serif; margin:0; padding:0; }
  header { display:flex; align-items:center; justify-content:space-between; padding:10px 20px; background:#f8f8f8; }
  nav a { margin:0 10px; text-decoration:none; color:#333; font-weight:bold; }
  .banner img { width:100%; max-height:150px; object-fit:cover; }
  h1,h2,h3 { margin:10px 0; }
  .product-grid { display:flex; flex-wrap:wrap; gap:10px; }
  .product-card { border:1px solid #ddd; padding:10px; width:calc(25% - 10px); box-sizing:border-box; text-align:center; }
  .product-card img { width:100%; height:150px; object-fit:cover; }
  button { margin:5px; padding:5px 10px; background:#333; color:#fff; border:none; cursor:pointer; }
  footer { text-align:center; padding:10px; background:#f1f1f1; margin-top:20px; }
  @media(max-width:768px){ .product-card{ width:48%; } }
  @media(max-width:480px){ .product-card{ width:100%; } }
</style>
</head>
<body>

<header>
  <img src="images/logo.png" alt="Logo" style="height:60px;">
  <nav>
    <a href="#home">Home</a>
    <a href="#shop">Shop</a>
    <a href="#cart">Cart</a>
    <a href="#wishlist">Wishlist</a>
    <a href="#admin">Admin</a>
  </nav>
</header>

<div class="banner">
  <img src="images/banner-free-shipping.png" alt="Free Shipping ₹5000+">
</div>

<main>

<!-- Home Section -->
<section id="home">
  <h1>Welcome to Stargazeboutique</h1>
  <p>Professional JS-free e-commerce store for fashion products.</p>
</section>

<!-- Shop Section -->
<section id="shop">
  <h2>Shop All Categories</h2>

  <!-- Kurti Sets -->
  <h3>Kurti Sets</h3>
  <div class="product-grid">
    <div class="product-card">
      <img src="images/product-images/kurti1.jpg" alt="Designer Kurti Set">
      <h3>Designer Kurti Set</h3>
      <p>Price: 149 AED</p>
      <p>Material: Cotton</p>
      <button>Edit</button><button>Delete</button>
    </div>
    <div class="product-card">
      <img src="images/product-images/kurti2.jpg" alt="Elegant Kurti Set">
      <h3>Elegant Kurti Set</h3>
      <p>Price: 159 AED</p>
      <p>Material: Cotton</p>
      <button>Edit</button><button>Delete</button>
    </div>
  </div>

  <!-- Lehenga -->
  <h3>Lehenga</h3>
  <div class="product-grid">
    <div class="product-card">
      <img src="images/product-images/lehenga1.jpg" alt="Wedding Lehenga">
      <h3>Wedding Lehenga</h3>
      <p>Price: 399 AED</p>
      <p>Material: Silk</p>
      <button>Edit</button><button>Delete</button>
    </div>
    <div class="product-card">
      <img src="images/product-images/lehenga2.jpg" alt="Party Lehenga">
      <h3>Party Lehenga</h3>
      <p>Price: 349 AED</p>
      <p>Material: Silk</p>
      <button>Edit</button><button>Delete</button>
    </div>
  </div>

  <!-- Additional categories: Saree, Gown, Plazzo, Indian Suit, Pakistan Suit, Nighty, Ladies Innerwear -->
</section>

<!-- Cart Section -->
<section id="cart">
  <h2>Shopping Cart</h2>
  <div class="product-card">
    <img src="images/product-images/kurti1.jpg" alt="Cart Item">
    <h3>Designer Kurti Set</h3>
    <p>Price: 149 AED</p>
    <p>Quantity: 1</p>
    <button>Remove</button>
  </div>
</section>

<!-- Wishlist Section -->
<section id="wishlist">
  <h2>Wishlist</h2>
  <div class="product-card">
    <img src="images/product-images/lehenga1.jpg" alt="Wishlist Item">
    <h3>Wedding Lehenga</h3>
    <p>Price: 399 AED</p>
    <button>Remove</button>
  </div>
</section>

<!-- Admin Section -->
<section id="admin">
  <h2>Admin Panel</h2>
  <p>Visual preview for edit/delete products.</p>
</section>

</main>

<footer>
  Stargazeboutique © 2026 | <a href="privacy.html">Privacy</a> | <a href="disclaimer.html">Disclaimer</a>
</footer>

</body>
</html>
