.hero-slider{
  position: relative;
  width: 100%;
  overflow: hidden;
}

.hero-slider img{
  width: 100%;
  display: block;
}

.hero-buttons{
  position: absolute;
  top: 50%;
  width: 100%;
  display: flex;
  justify-content: space-between;
  transform: translateY(-50%);
}

.hero-buttons button{
  background: rgba(0,0,0,0.5);
  color: white;
  border: none;
  padding: 10px;
  cursor: pointer;
  font-size: 20px;
}

.hero-buttons button:hover{
  background: rgba(0,0,0,0.7);
}
