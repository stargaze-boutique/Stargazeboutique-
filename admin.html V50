<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Panel – Stargaze Boutique</title>
<link rel="stylesheet" href="css/style.css">
<style>
body { font-family: Arial, sans-serif; padding: 20px; background:#f4f4f4;}
h1 { text-align:center;}
input, select { padding:5px; margin:5px;}
button { padding:5px 10px; margin:5px; cursor:pointer;}
.product-card { background:#fff; padding:10px; margin:10px 0; border-radius:5px; border:1px solid #ccc;}
</style>
</head>
<body>

<h1>Admin Panel – Products</h1>

<div>
  <h2>Add / Edit Product</h2>
  <input type="text" id="name" placeholder="Product Name">
  <input type="text" id="price" placeholder="Price (₹)">
  <input type="text" id="material" placeholder="Material / Fabric">
  <input type="text" id="image" placeholder="Image URL">
  <input type="text" id="category" placeholder="Category">
  <input type="text" id="badge" placeholder="Badge (New / Sale)">
  <input type="number" id="stock" placeholder="Stock">
  <button onclick="addProduct()">Add / Update Product</button>
</div>

<div>
  <h2>All Products</h2>
  <div id="list"></div>
</div>

<script>
let products = JSON.parse(localStorage.getItem("products")) || [];

// Add or update product
function addProduct(){
  const name = document.getElementById("name").value.trim();
  const price = document.getElementById("price").value.trim();
  const material = document.getElementById("material").value.trim();
  const image = document.getElementById("image").value.trim();
  const category = document.getElementById("category").value.trim();
  const badge = document.getElementById("badge").value.trim();
  const stock = document.getElementById("stock").value.trim();

  if(!name || !price || !image){ alert("Name, Price, and Image are required!"); return; }

  // Check if product already exists (by name)
  const existingIndex = products.findIndex(p => p.name === name);
  if(existingIndex > -1){
    // Update existing
    products[existingIndex] = { ...products[existingIndex], name, price, material, image, category, badge, stock };
  } else {
    // Add new
    const product = { id: Date.now(), name, price, material, image, category, badge, stock, sizes:["S","M","L","XL","XXL"] };
    products.push(product);
  }

  localStorage.setItem("products", JSON.stringify(products));
  render();
  clearForm();
}

// Delete product
function deleteProduct(i){
  if(confirm("Are you sure you want to delete this product?")){
    products.splice(i,1);
    localStorage.setItem("products", JSON.stringify(products));
    render();
  }
}

// Render products list
function render(){
  const list = document.getElementById("list");
  list.innerHTML = "";
  products.forEach((p,i)=>{
    list.innerHTML += `
      <div class="product-card">
        <strong>${p.name}</strong> – ₹${p.price} | ${p.material || 'N/A'} | Stock: ${p.stock}<br>
        Category: ${p.category || 'N/A'} | Badge: ${p.badge || 'N/A'}<br>
        <img src="${p.image}" alt="${p.name}" width="100"><br>
        <button onclick="deleteProduct(${i})">Delete</button>
      </div>
    `;
  });
}

// Clear input fields
function clearForm(){
  document.getElementById("name").value = "";
  document.getElementById("price").value = "";
  document.getElementById("material").value = "";
  document.getElementById("image").value = "";
  document.getElementById("category").value = "";
  document.getElementById("badge").value = "";
  document.getElementById("stock").value = "";
}

// Initial render
render();
</script>

</body>
</html>
