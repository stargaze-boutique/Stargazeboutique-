<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Stargaze Boutique</title>
<style>
body { font-family: Arial, sans-serif; margin:0; padding:0; background:#fff; }
header { background:#ff4081; color:#fff; padding:15px 20px; display:flex; justify-content:space-between; align-items:center; }
header a { color:#fff; text-decoration:none; margin-left:15px; }
.hero { width:100%; overflow:hidden; position:relative; border-radius:8px; height:300px; }
.hero img { width:100%; height:100%; display:none; position:absolute; top:0; left:0; object-fit:cover; transition: opacity 1s; }
.hero img.active { display:block; opacity:1; }
.categories { display:flex; overflow-x:auto; margin:20px 0; gap:10px; padding:0 10px; }
.categories button { flex:none; padding:10px 15px; border:none; background:#ff4081; color:#fff; border-radius:6px; cursor:pointer; }
.categories button:hover { background:#e73370; }
.product-grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap:20px; padding:0 10px; }
.product-card { border:1px solid #ddd; padding:15px; border-radius:8px; text-align:center; }
.product-card img { width:100%; border-radius:8px; }
.product-card button { margin-top:10px; background:#ff4081; color:white; border:none; padding:8px 12px; border-radius:6px; cursor:pointer; }
.product-card button:hover { background:#e73370; }
#clearCartHome { background:#ff1744; color:white; margin:10px 0; padding:8px 12px; border:none; border-radius:6px; cursor:pointer; }
footer { background:#333; color:#fff; text-align:center; padding:15px; margin-top:20px; }
</style>
</head>
<body>

<header>
<h1>Stargaze Boutique</h1>
<nav>
<a href="index.html">Home</a>
<a href="shop.html">Shop</a>
<a href="cart.html">Cart</a>
<a href="admin.html">Admin</a>
</nav>
</header>

<div class="hero" id="hero">
<img src="images/banner1.jpg" alt="Banner 1">
<img src="images/banner2.jpg" alt="Banner 2">
</div>

<div class="categories">
<button>Lehenga</button>
<button>Kurti</button>
<button>Saree</button>
<button>Gown</button>
<button>Pakistan Suit</button>
<button>India Suit</button>
<button>Ladies Innerwear</button>
</div>

<button id="clearCartHome">Clear Cart</button>

<div class="product-grid" id="productGrid"></div>

<footer>
© 2026 Stargaze Boutique. All rights reserved.
</footer>

<script>
// --------------------
// Products array (₹ currency)
// --------------------
const products = [
  { name: "Lehenga ABC", price: 1200, image: "images/lehenga1.jpg", category: "Lehenga" },
  { name: "Lehenga XYZ", price: 1500, image: "images/lehenga2.jpg", category: "Lehenga" },
  { name: "Kurti Blue", price: 800, image: "images/kurti1.jpg", category: "Kurti" },
  { name: "Saree Pink", price: 1000, image: "images/saree1.jpg", category: "Saree" },
  { name: "Gown Elegant", price: 2000, image: "images/gown1.jpg", category: "Gown" },
  { name: "Pakistan Suit Classic", price: 1100, image: "images/pakistan_suit1.jpg", category: "Pakistan Suit" },
  { name: "India Suit Modern", price: 1300, image: "images/india_suit1.jpg", category: "India Suit" },
  { name: "Ladies Innerwear Set", price: 500, image: "images/innerwear1.jpg", category: "Ladies Innerwear" }
];

// Display products
const productGrid = document.getElementById("productGrid");
products.forEach((product,index)=>{
    const card = document.createElement("div");
    card.className = "product-card";
    card.innerHTML = `
        <img src="${product.image}" alt="${product.name}">
        <h3>${product.name}</h3>
        <p>₹${product.price}</p>
        <button onclick="addToCartHome(${index})">Add to Cart</button>
        <button onclick="orderWhatsAppHome(${index})">Order via WhatsApp</button>
    `;
    productGrid.appendChild(card);
});

// Cart functions
function addToCartHome(index){
    let cart = JSON.parse(localStorage.getItem("cart")) || [];
    cart.push(products[index]);
    localStorage.setItem("cart", JSON.stringify(cart));
    alert("Product added to cart!");
}

function orderWhatsAppHome(index){
    let phone = "971XXXXXXXXX";
    let product = products[index];
    let message = `Hello, I want to order: ${product.name} - ₹${product.price}`;
    window.open(`https://wa.me/${phone}?text=${encodeURIComponent(message)}`);
}

// Clear Cart button
document.getElementById("clearCartHome").addEventListener("click", ()=>{
    localStorage.removeItem("cart");
    alert("Cart cleared!");
});

// Hero slider
const heroImages = document.querySelectorAll("#hero img");
let currentIndex = 0;
function showSlide(index){
    heroImages.forEach((img,i)=>{
        img.classList.remove("active");
        if(i===index) img.classList.add("active");
    });
}
function nextSlide(){
    currentIndex = (currentIndex + 1) % heroImages.length;
    showSlide(currentIndex);
}
showSlide(currentIndex);
setInterval(nextSlide, 5000);

// Swipe for touch devices
let startX = 0; let endX = 0;
const hero = document.getElementById("hero");
hero.addEventListener("touchstart", (e) => { startX = e.touches[0].clientX; });
hero.addEventListener("touchend", (e) => { endX = e.changedTouches[0].clientX; handleSwipe(); });
function handleSwipe(){
if(endX - startX > 50){ currentIndex = (currentIndex - 1 + heroImages.length) % heroImages.length; showSlide(currentIndex); }
else if(startX - endX > 50){ currentIndex = (currentIndex + 1) % heroImages.length; showSlide(currentIndex); }
}
</script>

</body>
</html>
