    <!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stargaze Boutique</title>
<link rel="stylesheet" href="style.css">
</head>
<body>

<header class="header">
  <div class="logo">STARGAZE</div>
  <nav>
    <a href="shop.html">Shop</a>
    <a href="lehenga.html">Lehenga</a>
    <a href="sarees.html">Sarees</a>
    <a href="kurti.html">Kurti</a>
    <a href="cart.html">Cart</a>
  </nav>
</header>

<section class="hero">
  <img src="images/banner1.jpg" alt="New Collection Banner">
  <div class="hero-text">
    <h1>NEW COLLECTION</h1>
    <a href="shop.html">SHOP NOW</a>
  </div>
</section>

<section class="categories">
  <div class="cat"><img src="images/lehenga1.jpg"><h3>Lehenga</h3></div>
  <div class="cat"><img src="images/saree1.jpg"><h3>Sarees</h3></div>
  <div class="cat"><img src="images/kurti1.jpg"><h3>Kurti</h3></div>
  <div class="cat"><img src="images/gown1.jpg"><h3>Gown</h3></div>
</section>

<section class="products" id="products"></section>

<a href="https://wa.me/919000000000" class="whatsapp">WhatsApp</a>

<footer>
  <p>© 2026 Stargaze Boutique</p>
</footer>

<script src="products.js"></script>
<script>
const container = document.getElementById("products");
products.forEach(p => {
  container.innerHTML += `
  <div class="product">
    <img src="${p.image}" alt="${p.name}">
    <h3>${p.name}</h3>
    <p>₹${p.price}</p>
    <button onclick="addCart(${p.id})">Add to Cart</button>
    <button onclick="buyWhatsApp('${p.name}',${p.price})">Buy on WhatsApp</button>
  </div>`;
});

let cart = [];
function addCart(id){
  let product = products.find(p=>p.id===id);
  cart.push(product);
  alert(product.name + " added to cart");
}
function buyWhatsApp(name, price){
  let msg = "Hello I want to buy " + name + " Price ₹" + price;
  window.open("https://wa.me/919000000000?text=" + encodeURIComponent(msg));
}
</script>

</body>
</html>
