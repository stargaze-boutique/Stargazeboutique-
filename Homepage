    <!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stargaze Boutique – Home</title>
  <link rel="stylesheet" href="css/style.css">
  <link rel="stylesheet" href="css/animations.css">
</head>
<body>

  <!-- Flash Sale Banner -->
  <div id="flashSaleBanner">🔥 Flash Sale! Up to 50% OFF – Limited Time!</div>

  <!-- Hero Slider -->
  <div class="hero-slider">
    <img id="heroImage" src="images/hero1.jpg" alt="Banner">
    <div class="hero-overlay">
      <h1>Summer Collection 2026</h1>
      <p>Up to 50% OFF</p>
      <button onclick="window.location.href='shop.html'">Shop Now</button>
    </div>
    <div class="hero-buttons">
      <button onclick="prevSlide()">❮</button>
      <button onclick="nextSlide()">❯</button>
    </div>
  </div>

  <!-- Category Filters -->
  <div id="categoryFilters">
    <button onclick="filterCategory('All')">All</button>
    <button onclick="filterCategory('Lehenga')">Lehenga</button>
    <button onclick="filterCategory('Kurti')">Kurti</button>
    <button onclick="filterCategory('Saree')">Saree</button>
    <button onclick="filterCategory('Gown')">Gown</button>
    <button onclick="filterCategory('Suit')">Suit</button>
  </div>

  <!-- Sort Dropdown -->
  <div id="filterSort">
    <select id="sortSelect" onchange="sortProducts(this.value)">
      <option value="default">Sort By</option>
      <option value="priceLow">Price: Low to High</option>
      <option value="priceHigh">Price: High to Low</option>
      <option value="nameAsc">Name: A-Z</option>
      <option value="nameDesc">Name: Z-A</option>
    </select>
  </div>

  <!-- Recently Viewed -->
  <h3>You Recently Viewed</h3>
  <div id="recentContainer"></div>

  <!-- Product Grid -->
  <div id="productList"></div>

  <!-- Mini Cart -->
  <div id="cartIcon">
    🛒 <span id="cartCount">0</span>
    <div id="miniCartDropdown">
      <h4>My Cart</h4>
      <div id="miniCartItems"></div>
      <p>Total: ₹<span id="miniCartTotal">0</span></p>
      <a href="cart.html">Go to Cart</a>
    </div>
  </div>

  <!-- Quick View Popup -->
  <div id="quickViewPopup">
    <span onclick="closeQuickView()">❌</span>
    <div id="quickViewContent"></div>
  </div>

  <!-- Newsletter Popup -->
  <div id="newsletterPopup">
    <span onclick="closeNewsletter()">❌</span>
    <h3>Subscribe to Our Newsletter</h3>
    <p>Get updates & exclusive discounts!</p>
    <input type="email" id="newsletterEmail" placeholder="Your Email"><br><br>
    <button onclick="subscribeNewsletter()">Subscribe</button>
  </div>

  <!-- JS Scripts -->
  <script src="js/products.js"></script>
  <script src="js/render.js"></script>
  <script src="js/cart.js"></script>
  <script src="js/wishlist.js"></script>
  <script src="js/hero-slider.js"></script>
  <script src="js/lazyload.js"></script>
  <script src="js/quickview.js"></script>
  <script src="js/filtersort.js"></script>
  <script src="js/newsletter.js"></script>

</body>
</html>
